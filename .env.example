# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Build with:  npm run build
# The token is baked into dist/extension.js at build time by esbuild.
# It does NOT appear in source control and is NOT user-configurable at runtime.

# Mixpanel project token (write-only — safe to bundle client-side)
# Found at: mixpanel.com → your project → Settings → Access Keys → Project Token
MIXPANEL_TOKEN=
