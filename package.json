{
  "name": "q-for-live",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && tsx build.js",
    "start": "tsx build.js && extensions-cli run",
    "build:prod": "tsx build.js --production",
    "package": "MIXPANEL_TOKEN=$MIXPANEL_TOKEN tsx build.js --production && npx extensions-cli package -o dist/llm-controller.ablx"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:./ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:./ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^25.9.1",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
